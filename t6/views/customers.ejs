<% layout('layout') %>

<h2>Asiakkaat ja käyttäjät</h2>

<table>
  <tr>
    <th>Yritys</th>
    <th>ID</th>
    <th>Nimi</th>
    <th>Email</th>
    <th>Admin</th>
  </tr>

  <% for (const row of rows) { %>
    <tr>
      <td><%= row.company_name %></td>
      <td><%= row.user_id %></td>
      <td><%= row.name %></td>
      <td><%= row.email %></td>
      <td><%= row.is_admin ? 'Kyllä' : 'Ei' %></td>
    </tr>
  <% } %>
</table>