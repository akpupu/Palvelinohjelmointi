<table border="1">
  <tr>
    <th>ID</th>
    <th>Asiakas</th>
    <th>Kuvaus</th>
    <th>Tila</th>
    <th>Saapunut</th>
    <th>Käsitelty</th>
    <th>Toiminnot</th>
  </tr>

  <nav>
  <a href="/customers">Asiakkaat ja käyttäjät</a> |
  <a href="/tickets">Tukipyynnöt</a> |
  <a href="/feedback">Palaute</a>
</nav>
  <% for (const row of rows) { %>
    <tr>
      <td><%= row.id %></td>
      <td><%= row.customer_name || 'Ei asiakasta' %></td>
      <td><%= row.description %></td>
      <td><%= row.status_text || 'Tuntematon tila' %></td>
      <td><%= row.arrived ? new Date(row.arrived).toLocaleString('fi-FI') : '---' %></td>
      <td><%= row.handled ? new Date(row.handled).toLocaleString('fi-FI') : 'Odottaa' %></td>
      <td>
        <a href="/support_ticket?id=<%= row.id %>" class="btn-view">Avaa tiedot</a>
      </td>
    </tr>
  <% } %>
</table>
